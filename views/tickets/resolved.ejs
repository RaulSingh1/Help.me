<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resolved Tickets - Help Desk</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('../partials/nav') %>

    <div class="container">
        <% const canSeeDeletedContent = user && user.isAdmin && showDeleted; %>

        <h1>Resolved Tickets</h1>

        <div class="actions">
            <a href="/tickets<%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>" class="btn">View Open Tickets</a>
            <a href="/tickets/search<%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>" class="btn">Search Tickets</a>
            <% if (user && user.isAdmin) { %>
                <a href="/tickets/resolved?showDeleted=<%= showDeleted ? '0' : '1' %>" class="btn btn-secondary"><%= showDeleted ? 'Skjul slettet' : 'Vis slettet' %></a>
            <% } %>
        </div>

        <% if (tickets.length === 0) { %>
            <p>No resolved tickets.</p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Priority</th>
                        <th>Created By</th>
                        <th>Resolved Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% tickets.forEach(ticket => { %>
                        <% const isDeletedTicket = Boolean(ticket.deletedAt); %>
                        <% const hideDeletedContent = isDeletedTicket && !canSeeDeletedContent; %>
                        <tr class="<%= isDeletedTicket ? 'row-deleted' : '' %>">
                            <td><%= hideDeletedContent ? '[deleted ticket]' : ticket.title %></td>
                            <td><%= hideDeletedContent ? '[deleted]' : ticket.priority %></td>
                            <td><%= hideDeletedContent ? '[deleted]' : (ticket.user ? ticket.user.username : 'Unknown') %></td>
                            <td><%= hideDeletedContent ? '[deleted]' : (ticket.resolvedAt ? ticket.resolvedAt.toLocaleDateString() : 'Unknown') %></td>
                            <td>
                                <a href="/tickets/<%= ticket._id %><%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>">View</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>
</body>
</html>
