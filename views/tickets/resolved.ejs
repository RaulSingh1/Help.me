<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Løste saker - Hjelpesenter</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('../partials/nav') %>

    <div class="container">
        <% const canSeeDeletedContent = user && user.isAdmin && showDeleted; %>
        <% const priorityLabels = { low: 'Lav', medium: 'Middels', high: 'Høy', urgent: 'Kritisk' }; %>

        <h1>Løste saker</h1>

        <div class="actions">
            <a href="/tickets<%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>" class="btn">Se åpne saker</a>
            <a href="/tickets/search<%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>" class="btn">Søk i saker</a>
            <% if (user && user.isAdmin) { %>
                <a href="/tickets/resolved?showDeleted=<%= showDeleted ? '0' : '1' %>" class="btn btn-secondary"><%= showDeleted ? 'Skjul slettet' : 'Vis slettet' %></a>
            <% } %>
        </div>

        <% if (tickets.length === 0) { %>
            <p>Ingen løste saker.</p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Tittel</th>
                        <th>Prioritet</th>
                        <th>Opprettet av</th>
                        <th>Løst av</th>
                        <th>Løst dato</th>
                        <th>Handlinger</th>
                    </tr>
                </thead>
                <tbody>
                    <% tickets.forEach(ticket => { %>
                        <% const isDeletedTicket = Boolean(ticket.deletedAt); %>
                        <% const hideDeletedContent = isDeletedTicket && !canSeeDeletedContent; %>
                        <tr class="<%= isDeletedTicket ? 'row-deleted' : '' %>">
                            <td><%= hideDeletedContent ? '[slettet sak]' : ticket.title %></td>
                            <td><%= hideDeletedContent ? '[slettet]' : (priorityLabels[ticket.priority] || ticket.priority) %></td>
                            <td><%= hideDeletedContent ? '[slettet]' : (ticket.user ? ticket.user.username : 'Ukjent') %></td>
                            <td><%= hideDeletedContent ? '[slettet]' : (ticket.resolvedBy ? ticket.resolvedBy.username : 'Ukjent') %></td>
                            <td><%= hideDeletedContent ? '[slettet]' : (ticket.resolvedAt ? ticket.resolvedAt.toLocaleDateString('no-NO') : 'Ukjent') %></td>
                            <td>
                                <a href="/tickets/<%= ticket._id %><%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>">Vis</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>
</body>
</html>
