<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Søk i saker - Hjelpesenter</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('../partials/nav') %>

    <div class="container">
        <% const canSeeDeletedContent = user && user.isAdmin && showDeleted; %>
        <% const statusLabels = { open: 'Åpen', 'in-progress': 'Under arbeid', resolved: 'Løst', closed: 'Lukket' }; %>
        <% const priorityLabels = { low: 'Lav', medium: 'Middels', high: 'Høy', urgent: 'Kritisk' }; %>

        <h1>Søk i saker</h1>

        <form action="/tickets/search" method="GET" class="search-form">
            <div class="form-group">
                <label for="q">Søk etter tittel, beskrivelse eller oppretter:</label>
                <input type="text" id="q" name="q" value="<%= typeof query !== 'undefined' ? query : '' %>" placeholder="Skriv inn søkeord..." required>
                <% if (user && user.isAdmin) { %>
                    <input type="hidden" name="showDeleted" value="<%= showDeleted ? '1' : '0' %>">
                <% } %>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn">Søk</button>
                <a href="/tickets<%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>" class="btn btn-secondary">Se alle saker</a>
                <% if (user && user.isAdmin) { %>
                    <a href="/tickets/search<%= typeof query !== 'undefined' ? ('?q=' + encodeURIComponent(query) + '&') : '?' %>showDeleted=<%= showDeleted ? '0' : '1' %>" class="btn btn-secondary"><%= showDeleted ? 'Skjul slettet' : 'Vis slettet' %></a>
                <% } %>
            </div>
        </form>

        <% if (typeof query !== 'undefined') { %>
            <h2>Resultater for: "<%= query %>"</h2>

            <% if (tickets.length === 0) { %>
                <p>Ingen saker matchet søket ditt. Prøv et annet søkeord.</p>
            <% } else { %>
                <p>Fant <%= tickets.length %> sak(er):</p>

                <table>
                    <thead>
                        <tr>
                            <th>Tittel</th>
                            <th>Prioritet</th>
                            <th>Status</th>
                            <th>Opprettet av</th>
                            <th>Handlinger</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tickets.forEach(ticket => { %>
                            <% const isDeletedTicket = Boolean(ticket.deletedAt); %>
                            <% const hideDeletedContent = isDeletedTicket && !canSeeDeletedContent; %>
                            <tr class="<%= isDeletedTicket ? 'row-deleted' : '' %>">
                                <td><%= hideDeletedContent ? '[slettet sak]' : ticket.title %></td>
                                <td><%= hideDeletedContent ? '[slettet]' : (priorityLabels[ticket.priority] || ticket.priority) %></td>
                                <td><%= isDeletedTicket ? 'Slettet' : (statusLabels[ticket.status] || ticket.status) %></td>
                                <td><%= hideDeletedContent ? '[slettet]' : (ticket.user ? ticket.user.username : 'Ukjent') %></td>
                                <td><a href="/tickets/<%= ticket._id %><%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>">Vis</a></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        <% } %>
    </div>
</body>
</html>
