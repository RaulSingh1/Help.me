<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Tickets - Help Desk</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('../partials/nav') %>

    <div class="container">
        <% const canSeeDeletedContent = user && user.isAdmin && showDeleted; %>

        <h1>Search Tickets</h1>

        <form action="/tickets/search" method="GET" class="search-form">
            <div class="form-group">
                <label for="q">Search by title, description, or creator:</label>
                <input type="text" id="q" name="q" value="<%= typeof query !== 'undefined' ? query : '' %>" placeholder="Enter search term..." required>
                <% if (user && user.isAdmin) { %>
                    <input type="hidden" name="showDeleted" value="<%= showDeleted ? '1' : '0' %>">
                <% } %>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn">Search</button>
                <a href="/tickets<%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>" class="btn btn-secondary">View All Tickets</a>
                <% if (user && user.isAdmin) { %>
                    <a href="/tickets/search<%= typeof query !== 'undefined' ? ('?q=' + encodeURIComponent(query) + '&') : '?' %>showDeleted=<%= showDeleted ? '0' : '1' %>" class="btn btn-secondary"><%= showDeleted ? 'Skjul slettet' : 'Vis slettet' %></a>
                <% } %>
            </div>
        </form>

        <% if (typeof query !== 'undefined') { %>
            <h2>Results for: "<%= query %>"</h2>

            <% if (tickets.length === 0) { %>
                <p>No tickets found matching your search. Try a different term.</p>
            <% } else { %>
                <p>Found <%= tickets.length %> ticket(s):</p>

                <table>
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Created By</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tickets.forEach(ticket => { %>
                            <% const isDeletedTicket = Boolean(ticket.deletedAt); %>
                            <% const hideDeletedContent = isDeletedTicket && !canSeeDeletedContent; %>
                            <tr class="<%= isDeletedTicket ? 'row-deleted' : '' %>">
                                <td><%= hideDeletedContent ? '[deleted ticket]' : ticket.title %></td>
                                <td><%= hideDeletedContent ? '[deleted]' : ticket.priority %></td>
                                <td><%= isDeletedTicket ? 'deleted' : ticket.status %></td>
                                <td><%= hideDeletedContent ? '[deleted]' : (ticket.user ? ticket.user.username : 'Unknown') %></td>
                                <td><a href="/tickets/<%= ticket._id %><%= user && user.isAdmin && showDeleted ? '?showDeleted=1' : '' %>">View</a></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        <% } %>
    </div>
</body>
</html>
