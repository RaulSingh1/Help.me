<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ny sak - Hjelpesenter</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('../partials/nav') %>

    <div class="container">
        <h1>Opprett ny sak</h1>

        <% if (typeof error !== 'undefined') { %>
            <div class="error-message">
                <%= error %>
            </div>
        <% } %>

        <form action="/tickets" method="POST" class="ticket-form">
            <div class="form-group">
                <label for="title">Tittel:</label>
                <input type="text" id="title" name="title" required placeholder="Kort beskrivelse av problemet">
            </div>

            <div class="form-group">
                <label for="description">Beskrivelse:</label>
                <textarea id="description" name="description" required rows="6" placeholder="Detaljert beskrivelse av problemet..."></textarea>
            </div>

            <div class="form-group">
                <label for="priority">Prioritet:</label>
                <select id="priority" name="priority">
                    <option value="low">Lav</option>
                    <option value="medium" selected>Middels</option>
                    <option value="high">Høy</option>
                    <option value="urgent">Kritisk</option>
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn">Opprett sak</button>
                <a href="/tickets" class="btn btn-secondary">Avbryt</a>
            </div>
        </form>
    </div>
</body>
</html>
